# Production Environment Configuration
# This file contains environment variables for the production environment

# Environment
VITE_APP_ENV=production
NODE_ENV=production

# Application Configuration
VITE_APP_NAME=VoiceFlow Pro
VITE_APP_VERSION=1.0.0
VITE_APP_URL=https://voiceflowpro.com

# AIML API Configuration
VITE_AIML_API_KEY=your_production_api_key_here
VITE_AIML_BASE_URL=https://api.aimlapi.com/v1
VITE_AIML_WS_URL=wss://api.aimlapi.com/v1/realtime

# Supabase Configuration (Production Project)
VITE_SUPABASE_URL=https://your-production-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_production_anon_key_here

# OAuth Configuration
VITE_ENABLE_OAUTH=true

# Stripe Configuration (Live Mode)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_production_key_here

# Feature Flags
VITE_ENABLE_REAL_TIME_STREAMING=true
VITE_ENABLE_OFFLINE_MODE=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_DEBUG_MODE=false

# Error Logging (Production)
VITE_ERROR_LOG_URL=https://errors.voiceflowpro.com/log

# E2E Testing (MUST be disabled in production)
VITE_ENABLE_E2E_AUTH_BYPASS=false

# Performance Monitoring
VITE_ENABLE_PERFORMANCE_MONITORING=true

# Encryption (Use production-specific key - KEEP SECRET!)
VITE_ENCRYPTION_KEY=your_production_encryption_key_here
