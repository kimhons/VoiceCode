# Staging Environment Configuration
# This file contains environment variables for the staging environment

# Environment
VITE_APP_ENV=staging
NODE_ENV=production

# Application Configuration
VITE_APP_NAME=VoiceFlow Pro (Staging)
VITE_APP_VERSION=1.0.0-staging
VITE_APP_URL=https://staging.voiceflowpro.com

# AIML API Configuration
VITE_AIML_API_KEY=your_staging_api_key_here
VITE_AIML_BASE_URL=https://api.aimlapi.com/v1
VITE_AIML_WS_URL=wss://api.aimlapi.com/v1/realtime

# Supabase Configuration (Staging Project)
VITE_SUPABASE_URL=https://your-staging-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_staging_anon_key_here

# OAuth Configuration
VITE_ENABLE_OAUTH=true

# Stripe Configuration (Test Mode)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_staging_key_here

# Feature Flags
VITE_ENABLE_REAL_TIME_STREAMING=true
VITE_ENABLE_OFFLINE_MODE=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_DEBUG_MODE=true

# Error Logging (Staging)
VITE_ERROR_LOG_URL=https://staging-errors.voiceflowpro.com/log

# E2E Testing (Disabled in staging by default)
VITE_ENABLE_E2E_AUTH_BYPASS=false

# Performance Monitoring
VITE_ENABLE_PERFORMANCE_MONITORING=true

# Encryption (Use staging-specific key)
VITE_ENCRYPTION_KEY=your_staging_encryption_key_here
