# AIML API Configuration
# Get your API key from https://aimlapi.com
VITE_AIML_API_KEY=your_api_key_here
VITE_AIML_BASE_URL=https://api.aimlapi.com/v1
VITE_AIML_WS_URL=wss://api.aimlapi.com/v1/realtime


# Application Configuration
VITE_APP_NAME=VoiceCode
VITE_APP_VERSION=1.0.0

# ============================================
# Supabase Configuration (Required)
# ============================================
# Get these from: https://app.supabase.com → Your Project → Settings → API

# Supabase Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anonymous (Public) Key - Safe to expose in browser
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# Stripe Payment Configuration (Required)
# ============================================
# Get these from: https://dashboard.stripe.com → Developers → API keys

# Stripe Publishable Key - Safe to expose in browser
# Test mode: pk_test_... | Live mode: pk_live_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx

# Stripe Price IDs - Get from: https://dashboard.stripe.com → Products
# Pro Plan - Monthly ($7.99/month)
VITE_STRIPE_PRO_MONTHLY_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxx

# Pro Plan - Yearly ($6.99/month, billed annually = $83.88/year)
VITE_STRIPE_PRO_YEARLY_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxx

# Enterprise Plan - Monthly ($14.99/month)
VITE_STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxx

# Enterprise Plan - Yearly ($12.99/month, billed annually = $155.88/year)
VITE_STRIPE_ENTERPRISE_YEARLY_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxx

# ============================================
# Optional: Third-Party Services
# ============================================

# Sentry Error Tracking (for production monitoring)
# Get from: https://sentry.io → Settings → Projects → Client Keys (DSN)
# VITE_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# Google Analytics (for usage analytics)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# OpenAI API Key (if using additional AI features)
# Get from: https://platform.openai.com/api-keys
# VITE_OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx

# ============================================
# Feature Flags
# ============================================
VITE_ENABLE_REAL_TIME_STREAMING=false
VITE_ENABLE_OFFLINE_MODE=true
VITE_ENABLE_ANALYTICS=false
VITE_ERROR_LOG_URL=

# ============================================
# Development Settings
# ============================================

# Environment (development, staging, production)
# VITE_ENV=development

# Enable debug logging
# VITE_DEBUG=true

# ============================================
# Important Notes
# ============================================
#
# 1. NEVER commit the .env file to version control
# 2. All variables prefixed with VITE_ are exposed to the browser
# 3. Keep secret keys (service_role, secret keys) in Supabase Edge Functions only
# 4. Use test mode keys for development (pk_test_, sk_test_)
# 5. Switch to live mode keys only when ready for production
#
# For deployment guide, see: STRIPE_DEPLOYMENT_GUIDE.md
# For more information:
# - Supabase: https://supabase.com/docs
# - Stripe: https://stripe.com/docs
# - Vite env: https://vitejs.dev/guide/env-and-mode.html


