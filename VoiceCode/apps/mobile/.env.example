# Supabase Configuration (Required)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# AIML API Configuration (Required for transcription)
EXPO_PUBLIC_AIML_API_KEY=your-aiml-api-key-here
EXPO_PUBLIC_AIML_BASE_URL=https://api.aimlapi.com/v1
EXPO_PUBLIC_AIML_WS_URL=wss://api.aimlapi.com/v1/realtime

# Stripe Payment Configuration (Required for payments)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key-here
EXPO_PUBLIC_STRIPE_PRO_MONTHLY_PRICE_ID=price_pro_monthly_id
EXPO_PUBLIC_STRIPE_PRO_YEARLY_PRICE_ID=price_pro_yearly_id
EXPO_PUBLIC_STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=price_enterprise_monthly_id
EXPO_PUBLIC_STRIPE_ENTERPRISE_YEARLY_PRICE_ID=price_enterprise_yearly_id

# App Configuration
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_API_TIMEOUT=30000

# Feature Flags (Optional)
EXPO_PUBLIC_ENABLE_BIOMETRIC_AUTH=true
EXPO_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=true
EXPO_PUBLIC_ENABLE_OFFLINE_MODE=true
EXPO_PUBLIC_ENABLE_ANALYTICS=false

# Sentry (Optional - for error tracking)
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_ENVIRONMENT=development

# Analytics (Optional)
EXPO_PUBLIC_ANALYTICS_ENABLED=false

