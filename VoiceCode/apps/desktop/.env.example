# VoiceCode Desktop Environment Variables
# Copy this file to .env and fill in your values

# Required for encryption features (minimum 32 characters)
VITE_ENCRYPTION_KEY=your-32-character-minimum-encryption-key-here

# Optional: Supabase configuration (for cloud sync features)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: AI ML API configuration
# VITE_AI_ML_API_KEY=your-ai-ml-api-key
# VITE_AI_ML_API_URL=https://api.aiml.example.com
