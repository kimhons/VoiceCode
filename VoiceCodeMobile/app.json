{
  "expo": {
    "name": "VoiceCode",
    "slug": "voicecode",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "voicecode",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.voicecode.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "VoiceCode needs access to your microphone to record voice notes and transcribe audio.",
        "NSSpeechRecognitionUsageDescription": "VoiceCode uses speech recognition to transcribe your voice recordings.",
        "UIBackgroundModes": [
          "audio",
          "fetch"
        ]
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.voicecode.app",
      "versionCode": 1,
      "permissions": [
        "RECORD_AUDIO",
        "WRITE_EXTERNAL_STORAGE",
        "READ_EXTERNAL_STORAGE",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [





      [
        "expo-notifications",





        {
          "icon": "./assets/notification-icon.png",
          "color": "#ffffff",
          "sounds": [
            "./assets/notification-sound.wav"
          ]
        }
      ],





      [
        "expo-av",





        {
          "microphonePermission": "Allow VoiceCode to access your microphone for voice recording."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "voicecode-mobile"
      }
    },
    "owner": "voicecode",
    "updates": {
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/voicecode-mobile"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
